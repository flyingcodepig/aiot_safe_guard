# ============================================
# 智御物联 — 环境变量模板
# 复制此文件为 backend/.env 并修改实际值
# ============================================

# --- LLM API ---
OPENAI_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=10
LLM_MAX_RETRIES=0

# --- 安全层开关（true/false）---
ENABLE_LLM_PLANNER=true
ENABLE_LLM_FACT_CHECKS=true
ENABLE_LLM_GUARD_SCANNER=true
SELFCHECK_ENABLED=true
ENABLE_SELFCHECK_GATE=true
ENABLE_INPUT_GUARD=true
ENABLE_DEVICE_GATE=true
ENABLE_INTENT_GATE=true
ENABLE_FACT_CHECKER=true
ENABLE_POLICY_ENGINE=true
ENABLE_PHYSICAL_CHECKER=true

# --- SelfCheck 配置 ---
SELFCHECK_METHOD=llm_prompt
SELFCHECK_THRESHOLD=0.5
SELFCHECK_SAMPLE_COUNT=3

# --- 数据库 ---
DATABASE_URL=sqlite:///./aiot_guard.db

# --- 设备配置目录 ---
DEVICE_CONFIG_DIR=./data/devices

# --- 服务器 ---
PORT=8000

# --- API 认证 ---
# 本地开发用默认值；生产环境务必修改
API_KEY=aiot-dev-key-change-in-production

# --- Docker ---
ENVIRONMENT=local
